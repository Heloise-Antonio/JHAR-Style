<!DOCTYPE html>
<html lang="pt-br">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Academia</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
</head>
<body class="bg-light">

    <!-- Breadcrumb -->
    <nav class="container my-3">
        <ol class="breadcrumb mb-1">
            <li class="breadcrumb-item active">Beach Tenis</li>
        </ol>
        <span class="badge bg-light text-dark border">
            <img src="https://cdn-icons-png.flaticon.com/512/3514/3514490.png" alt="Carrinho" style="width:16px;height:16px;">
            Envio Nacional
        </span>
    </nav>

    <!-- Produtos -->
    <div class="container my-4">
        <div class="row row-cols-1 row-cols-sm-2 row-cols-md-4 g-4 text-center d-flex w-100 justify-content-around min-vw-100">

            <div class="col">
                <div class="card h-100 border-0">
                    <img src="~/img/Conjunto Feminino Beach Tennis .png" class="card-img-top tamanho-imagem" alt="Conjunto Feminino Beach Tenis">
                    <div class="card-body">
                        <p class="mb-1">Conjunto Beach tenis </p>
                        <h6 class="text-danger fw-bold">R$130,00</h6>
                        <a asp-controller="Home" asp-action="Detalhes" class="btn btn-danger px-4">Detalhes</a>
                    </div>
                </div>
            </div>

            <div class="col">
                <div class="card h-100 border-0">
                    <img src="~/img/Vestido esportivo para beach tennis.png" class="card-img-top tamanho-imagem" alt="Vestido esportivo">
                    <div class="card-body">
                        <p class="mb-1">Vestido esportivo</p>
                        <h6 class="text-danger fw-bold">R$145,90</h6>
                        <a asp-controller="Home" asp-action="Detalhes" class="btn btn-danger px-4">Detalhes</a>
                    </div>
                </div>
            </div>

            <div class="col">
                <div class="card h-100 border-0">
                    <img src="~/img/Raquete Beach tennis + bolsa.webp" class="card-img-top tamanho-imagem" alt="Raquete Beach Tennis + Bolsa">
                    <div class="card-body">
                        <p class="mb-1">Raquete Beach Tennis + Bolsa</p>
                        <h6 class="text-danger fw-bold">R$235,00</h6>
                        <a asp-controller="Home" asp-action="Detalhes" class="btn btn-danger px-4">Detalhes</a>
                    </div>
                </div>
            </div>

            <div class="col">
                <div class="card h-100 border-0">
                    <img src="~/img/Kit completo beach tennis.png" class="card-img-top tamanho-imagem" alt="Kit completo beach tennis">
                    <div class="card-body">
                        <p class="mb-1">Kit completo beach tennis</p>
                        <h6 class="text-danger fw-bold">R$340,00</h6>
                        <a asp-controller="Home" asp-action="Detalhes" class="btn btn-danger px-4">Detalhes</a>
                    </div>
                </div>
            </div>

        </div>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>
