<!DOCTYPE html>
<html lang="pt-br">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Academia</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
</head>
<body class="bg-light">

    <!-- Breadcrumb -->
    <nav class="container my-3">
        <ol class="breadcrumb mb-1">
            <li class="breadcrumb-item active">Futebol</li>
        </ol>
        <span class="badge bg-light text-dark border">
            <img src="https://cdn-icons-png.flaticon.com/512/3514/3514490.png" alt="Carrinho" style="width:16px;height:16px;">
            Envio Nacional
        </span>
    </nav>

    <!-- Produtos -->
    <div class="container my-4">
        <div class="row row-cols-1 row-cols-sm-2 row-cols-md-4 g-4 text-center d-flex w-100 justify-content-around min-vw-100">

            <div class="col">
                <div class="card h-100 border-0 borda-card">
                    <img src="~/img/Futebol Corinthians.png" class="card-img-top tamanho-imagem" alt="Corinthians">
                    <div class="card-body">
                        <p class="mb-1">Conjunto Original Corinthians</p>
                        <h6 class="text-danger fw-bold">R$590,00</h6>
                        <a asp-controller="Home" asp-action="Detalhes" class="btn btn-danger px-4">Detalhes</a>
                    </div>
                </div>
            </div>

            <div class="col">
                <div class="card h-100 border-0">
                    <img src="~/img/Futebol Flamengo.png" class="card-img-top tamanho-imagem" alt="Flamengo">
                    <div class="card-body">
                        <p class="mb-1">Conjunto Original Flamengo</p>
                        <h6 class="text-danger fw-bold">R$500,90</h6>
                        <a asp-controller="Home" asp-action="Detalhes" class="btn btn-danger px-4">Detalhes</a>
                    </div>
                </div>
            </div>

            <div class="col">
                <div class="card h-100 border-0">
                    <img src="~/img/Futebol Palmeiras.png" class="card-img-top tamanho-imagem" alt="Palmeiras">
                    <div class="card-body">
                        <p class="mb-1"> Conjunto Original Palmeiras</p>
                        <h6 class="text-danger fw-bold">R$520,00</h6>
                        <a asp-controller="Home" asp-action="Detalhes" class="btn btn-danger px-4">Detalhes</a>
                    </div>
                </div>
            </div>

            <div class="col">
                <div class="card h-100 border-0">
                    <img src="~/img/Futebol Brasil.jpg" class="card-img-top tamanho-imagem" alt="Brasil">
                    <div class="card-body">
                        <p class="mb-1">Conjunto Original Seleção Brasileira</p>
                        <h6 class="text-danger fw-bold">R$569,90</h6>
                        <a asp-controller="Home" asp-action="Detalhes" class="btn btn-danger px-4">Detalhes</a>
                    </div>
                </div>
            </div>

        </div>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>
