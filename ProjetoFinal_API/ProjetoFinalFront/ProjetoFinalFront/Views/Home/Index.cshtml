@{
    ViewData["Title"] = "Moda Esportiva";
}

<style>
    /* Remove margens e garante largura total */
    html, body {
        margin: 0;
        padding: 0;
        width: 100%;
    }

    .banner-full {
        width: 100vw;
        height: auto;
        display: block;
    }

    .gallery-container {
        width: 100vw;
        margin: 0;
        padding: 0;
    }

    .gallery-row img {
        width: 100%;
        height: auto;
        object-fit: cover;
    }
    /* Remove limites de container padrão */
    .container, .container-fluid {
        max-width: 100% !important;
        padding-left: 0 !important;
        padding-right: 0 !important;
    }

    /* Banner ocupa 100% da tela */
    .banner-full {
        width: 100vw !important;
        height: auto;
        display: block;
    }

    /* Galeria de produtos ocupa 100% */
    .gallery-full {
        width: 100vw !important;
        margin: 0 !important;
        padding: 0 2vw !important; /* espaço lateral opcional */
    }

        .gallery-full .card img {
            width: 100% !important;
            height: auto;
            object-fit: cover;
        }
</style>

<div class="container-fluid p-0">

    <!-- Banner principal ocupando 100% da tela -->
    <div class="row g-0">
        <img src="~/img/bannerHome.png" class="banner-full" alt="Shape Design">
    </div>

    <!-- Galeria de produtos ocupando 100% da largura -->
    <div class="gallery-container my-5">
        <div class="row g-4 gallery-row mx-0 px-4">
            <div class="col-6 col-md-3">
                <div class="card border-0">
                    <img src="~/img/corrida roupa 1 1.png" alt="Produto 1" style="width: 350px; height:450px;">
                    <div class="card-body">
                        <p class="mb-1">Conjunto All Black Masculino - MAN JHAR</p>
                        <h6 class="text-danger fw-bold">R$125,90</h6>
                        <a asp-controller="Home" asp-action="Detalhes" class="btn btn-danger px-4">Detalhes</a>
                    </div>
                </div>
            </div>
            <div class="col-6 col-md-3">
                <div class="card border-0">
                    <img src="~/img/academia roupa 1 1.png" alt="Produto 2" style="width: 350px; height:450px">
                    <div class="card-body">
                        <p class="mb-1">Conjunto de treino Verde Água - JHAR</p>
                        <h6 class="text-danger fw-bold">R$109,90</h6>
                        <a asp-controller="Home" asp-action="Detalhes" class="btn btn-danger px-4">Detalhes</a>
                    </div>
                </div>
            </div>
            <div class="col-6 col-md-3">
                <div class="card border-0">
                    <img src="~/img/Design sem nome (1) 1.png" alt="Produto 3" style="width: 350px; height:450px">
                    <div class="card-body">
                        <p class="mb-1">Traje impermeável para nado - JHAR</p>
                        <h6 class="text-danger fw-bold">R$239,90</h6>
                        <a asp-controller="Home" asp-action="Detalhes" class="btn btn-danger px-4">Detalhes</a>
                    </div>
                </div>
            </div>
            <div class="col-6 col-md-3">
                <div class="card border-0">
                    <img src="~/img/futebol roupa 1 1.png" alt="Produto 4" style="width: 350px; height:450px">
                    <div class="card-body">
                        <p class="mb-1">Conjunto Térmico all White para corrida - JHAR</p>
                        <h6 class="text-danger fw-bold">R$179,90</h6>
                        <a asp-controller="Home" asp-action="Detalhes" class="btn btn-danger px-4">Detalhes</a>
                    </div>
                </div>
            </div>
        </div>
    </div>


    <div class="gallery-container my-5">
        <div class="row g-4 gallery-row mx-0 px-4">
            <div class="col-6 col-md-3">
                <div class="card border-0">
                    <img src="~/img/verde.png" class="card-img-top  tamanho-imagem" alt="Conjunto Verde Ciano">
                    <div class="card-body">
                        <p class="mb-1">Conjunto Verde Ciano</p>
                        <h6 class="text-danger fw-bold">R$120,90</h6>
                        <a asp-controller="Home" asp-action="Detalhes" class="btn btn-danger px-4">Detalhes</a>
                    </div>
                </div>
            </div>
            <div class="col-6 col-md-3">
                <div class="card border-0">
                    <img src="~/img/Conjunto Feminino Beach Tennis .png" style="height: 470px" class="card-img-top tamanho-imagem" alt="Conjunto Feminino Beach Tenis">
                    <div class="card-body">
                        <p class="mb-1">Conjunto Beach tenis </p>
                        <h6 class="text-danger fw-bold">R$130,00</h6>
                        <a asp-controller="Home" asp-action="Detalhes" class="btn btn-danger px-4">Detalhes</a>
                    </div>
                </div>
            </div>
            <div class="col-6 col-md-3">
                <div class="card border-0">
                    <img src="~/img/Isotermica Fem natacao.png" style="height: 470px" class="card-img-top tamanho-imagem" alt=" Roupa Isotérmica Feminina mergulho">
                    <div class="card-body">
                        <p class="mb-1">Roupa Isotérmica Femininapara Mergulho</p>
                        <h6 class="text-danger fw-bold">R$100,00</h6>
                        <a asp-controller="Home" asp-action="Detalhes" class="btn btn-danger px-4">Detalhes</a>
                    </div>
                </div>
            </div>
            <div class="col-6 col-md-3">
                <div class="card border-0">
                    <img src="~/img/Futebol Brasil.jpg" style="height: 470px"  class="card-img-top tamanho-imagem" alt="Brasil">
                    <div class="card-body">
                        <p class="mb-1">Conjunto Original Seleção Brasileira</p>
                        <h6 class="text-danger fw-bold">R$569,90</h6>
                        <a asp-controller="Home" asp-action="Detalhes" class="btn btn-danger px-4">Detalhes</a>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

