@{
    Layout = null;
}
<!DOCTYPE html>
<html lang="pt-br">
<head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <title>Login / Registro</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <style>
        body {
           
        }

        .left-panel {
            background-color: #a30000;
            color: #fff;
            border-top-right-radius: 50%;
            border-bottom-right-radius: 50%;
            min-height: 100vh;
        }

            .left-panel h1 {
                font-weight: 900;
            }

            .left-panel p {
                font-size: 1rem;
            }
    </style>
</head>
<body>

    <div class="container-fluid min-vh-100 d-flex p-0">
 
                        <!-- Lado Esquerdo -->
                        <div class="col-md-5 d-flex justify-content-center align-items-center left-panel">
                            <div class="text-center">
                                <img src="~/img/Logo Print.png" class="img-fluid" /> 
                            </div>
                        </div>

                        <!-- Lado Direito -->
                        <div class="col-md-7 bg-white d-flex justify-content-center align-items-center">
                            <div class="w-75">

                <div>
                    <h1>Seja Bem-Vindo ao nosso Site!</h1>
                    <p class="mt-3">
                        <img src="https://img.icons8.com/?size=100&id=64776&format=png&color=000000" alt="Cadeado" style="height: 20px;">
                        Seus dados estão protegidos!
                    </p>
                </div>

                                <form>
                                    <div class="mb-3" style="margin-top: 40px;">
                                        <label class="form-label">Nome Completo</label>
                                        <input type="text" class="form-control bg-danger bg-opacity-25 border-0">
                                    </div>
                                    <div class="mb-3">
                                        <label class="form-label">E-mail</label>
                                        <input type="email" class="form-control bg-danger bg-opacity-25 border-0">
                                    </div>
                                    <div class="mb-3">
                                        <label class="form-label">Senha</label>
                                        <input type="password" class="form-control bg-danger bg-opacity-25 border-0">
                                    </div>
                                    <div class="form-check mb-4">
                                        <input class="form-check-input" type="checkbox" id="mostrarSenha">
                                        <label class="form-check-label" for="mostrarSenha">Mostrar senha</label>
                                    </div>
                                    <div class="d-flex justify-content-between">
                        <button type="button" class="btn btn-danger px-4" onclick="window.location.href='Login'">ENTRAR</button>
                                    </div>
                                </form>
                            </div>
                        </div>
                    </div>
                </div>
     
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.js"></script>
</body>
</html>
