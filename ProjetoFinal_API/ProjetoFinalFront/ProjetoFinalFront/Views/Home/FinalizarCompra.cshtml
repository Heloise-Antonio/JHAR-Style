

<!DOCTYPE html>
<html lang="pt-br">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Resumo da Compra</title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">

  <style>
    html, body {
      height: 100%;
      margin: 0;
      padding: 0;
    }

    body {
      display: flex;
      flex-direction: column;
      background-color: #fff;
      font-family: Arial, sans-serif;
    }

    .resumo-box {
      max-width: 900px;
      margin: 5px auto 0 auto;
      padding: 20px;
      flex: 1;
    }

    .produto {
      display: flex;
      justify-content: space-between;
      align-items: flex-start;
      border-bottom: 1px solid #ccc;
      padding-bottom: 10px;
    }

    .produto img {
      width: 250px;
      height: auto;
      object-fit: cover;
      border: 1px solid #ccc;
      border-radius: 5px;
    }

    .produto-info {
      margin-left: 10px;
    }

    .preco-total {
      font-size: 1.2rem;
      font-weight: bold;
      color: #111;
    }

    .frete {
      color: #d00;
      font-weight: bold;
    }

    .btn-comprar {
      background-color: #900;
      color: white;
      padding: 10px 30px;
      border: none;
      transition: background-color 0.3s ease;
    }

    .btn-comprar:hover {
      background-color: #700;
    }

    .footer {
      background-color: #e0bebe;
      padding: 30px 0;
      text-align: center;
      width: 1525px;
    }

    .footer img {
      height: 25px;
      margin: 0 5px;
    }

    .footer .social img {
      height: 30px;
      margin: 0 8px;
    }

    @@media (max-width: 768px) {
      .produto {
        flex-direction: column;
        align-items: center;
        text-align: center;
      }

      .produto-info {
        margin-left: 0;
        margin-top: 15px;
      }

    }
  </style>
</head>
<body>

  <!-- Conteúdo do Carrinho -->
  <div class="container resumo-box">
    <h3 class="mb-4 text-center">Meu Carrinho</h3>

    <div class="produto">
      <div class="d-flex flex-row">
      <img src="~/img/verde.png" alt="Conjunto Verde Ciano">
        <div class="produto-info">
          <h5>Conjunto Verde Ciano</h5>
          <p class="fw-bold mb-1">R$ 250,90</p>
          <p class="mb-0">Tam: P</p>
        </div>
      </div>

      <div class="text-end">
        <p class="frete mb-2">Frete<br>R$ 12,00</p>
        <button class="btn btn-secondary mb-2" onclick="window.location.href='Detalhes'">Voltar</button>
        <p class="preco-total">R$ 262,90</p>
        <button class="btn btn-comprar">Comprar</button>
      </div>
    </div>
  </div>

    <!-- Rodapé Atualizado -->
    <div class="footer">
        <div class="d-flex justify-content-around flex-wrap mb-3">

            <!-- Pagamentos -->
            <div>
                <strong>ACEITAMOS</strong><br>
                <img src="https://upload.wikimedia.org/wikipedia/commons/4/41/Visa_Logo.png" alt="Visa">
                <img src="https://upload.wikimedia.org/wikipedia/commons/0/04/Mastercard-logo.png" alt="Mastercard">
                <img src="https://img.icons8.com/?size=100&id=F77TABNQzR3w&format=png&color=000000" alt="Boleto" style="height: 25px;">
            </div>

            <!-- Redes sociais -->
            <div>
                <strong>FIQUE POR DENTRO DAS NOVIDADES</strong><br>
                <div class="social">
                    <img src="https://img.icons8.com/?size=100&id=118497&format=png&color=000000" alt="Facebook">
                    <img src="https://upload.wikimedia.org/wikipedia/commons/a/a5/Instagram_icon.png" alt="Instagram">
                    <img src="https://upload.wikimedia.org/wikipedia/commons/6/6b/WhatsApp.svg" alt="WhatsApp">
                    <img src="https://img.icons8.com/?size=100&id=13963&format=png&color=000000" alt="X">
                </div>
            </div>

            <!-- Entrega -->
            <div>
                <strong>ENTREGA EXPRESSA</strong><br>
                <img src="https://img.icons8.com/?size=100&id=86719&format=png&color=000000" alt="Entrega" style="height: 30px;">
            </div>
        </div>

        <!-- Suporte a dispositivos -->
        <p class="mt-3">
            Nosso site está disponível para
            <img src="https://img.icons8.com/?size=100&id=85911&format=png&color=000000" alt="Mobile" style="height: 20px;">
            <img src="https://img.icons8.com/?size=100&id=4157&format=png&color=000000" alt="PC" style="height: 20px;">
        </p>
    </div>


  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>
